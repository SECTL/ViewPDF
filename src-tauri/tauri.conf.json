{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "viewpdf",
  "version": "0.0.3",
  "identifier": "SECTL.viewpdf",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "fullscreen": false,
        "resizable": true,
        "center": true,
        "label": "main",
        "title": "viewpdf",
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc.localhost: http://ipc.localhost data: blob: tauri.localhost: http://tauri.localhost; media-src 'self' blob: data:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' asset: http://asset.localhost; img-src 'self' data: blob: asset: http://asset.localhost; worker-src 'self' blob:;",
      "assetProtocol": {
        "enable": false,
        "scope": {
          "allow": ["$APPDATA/themes/**/*"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installerHooks": "./installer-hooks.nsh",
        "languages": ["SimpChinese", "English"],
        "installMode": "perMachine"
      }
    },
    "icon": [
      "icons/Square1024x1024Logo.png",
      "icons/Square1024x1024Logo.png",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/pdf.ico",
      "icons/word.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "PDF Document",
        "role": "Viewer",
        "mimeType": "application/pdf"
      },
      {
        "ext": ["docx"],
        "name": "Word Document",
        "role": "Viewer",
        "mimeType": "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
      },
      {
        "ext": ["doc"],
        "name": "Word 97-2003 Document",
        "role": "Viewer",
        "mimeType": "application/msword"
      }
    ]
  },
  "plugins": {
    "opener": {}
  }
}
